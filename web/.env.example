# Aribot web env vars
# Copy to .env.local and fill in real values from Supabase Dashboard → Settings → API.
# NEXT_PUBLIC_ vars are baked into the browser bundle at build time — only put
# values here that are safe to expose. The anon key is designed for browser
# use (RLS protects data); the service_role key MUST NOT go here.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Backend sidecar — used by future milestones (M2+) for status/positions calls.
# Optional in M1.
NEXT_PUBLIC_ARIBOT_API_URL=https://api.aribot.app
