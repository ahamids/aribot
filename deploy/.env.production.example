# =====================================================================
# Aribot production environment template
#
# Copy to /etc/aribot/aribot.env on the production server, fill in real
# values, then `chmod 600 /etc/aribot/aribot.env && chown root:root` it.
# Never commit a filled-in copy of this file.
# =====================================================================

# ─── Multi-tenant sidecar (Phase 5+ default) ─────────────────────────
# REQUIRED. Without these the sidecar refuses to boot (exit code 2)
# unless --legacy-single-user is passed.
#
# Production Supabase project (different from dev):
#   1. https://supabase.com → New Project (region: Southeast Asia)
#   2. Project Settings → API → Project URL and JWT Secret
SUPABASE_URL=https://REPLACE-WITH-PROD-REF.supabase.co
SUPABASE_JWT_SECRET=REPLACE_WITH_PROD_JWT_SECRET

# Per-tenant artifact root. Each user gets a subdir under
# <ARIBOT_ARTIFACT_DIR>/tenants/<user_uuid>/. The systemd unit grants
# write access only to this path; do not change without also updating
# ReadWritePaths= in aribot-sidecar.service.
ARIBOT_ARTIFACT_DIR=/var/lib/aribot/.aribot

# Python keyring — file backend for headless Linux.
# install.sh wrote /var/lib/aribot/.config/python_keyring/keyringrc.cfg
# pointing at keyrings.alt.file.PlaintextKeyring; these XDG paths tell
# the library where to look. Bot X25519 secret lands at
# /var/lib/aribot/.local/share/python_keyring/keyring_pass.cfg
# (mode 600, aribot-owned). Backed up by deploy/backup.sh.
XDG_CONFIG_HOME=/var/lib/aribot/.config
XDG_DATA_HOME=/var/lib/aribot/.local/share

# ─── Sidecar legacy bearer (still useful as ops escape hatch) ────────
# A leaked legacy token cannot push or wipe credentials in multi-tenant
# mode (the /credentials* endpoints are JWT-only). It IS still an admin
# bearer for the legacy code paths and any future ops endpoints.
# Generate: openssl rand -hex 32
ARIBOT_API_TOKEN=REPLACE_WITH_RANDOM_HEX

# Optional separate token if/when an /admin namespace is added. Falls
# back to ARIBOT_API_TOKEN when unset.
ARIBOT_API_TOKEN_VAULT=

# ─── Bybit (operator's own tenant only; multi-tenant users push their
# keys via the iOS app) ──────────────────────────────────────────────
# In production, the operator typically runs in PAPER or SHADOW mode
# only, with Bybit testnet keys, to validate end-to-end without risk.
# LIVE mode for the operator's own tenant requires iOS-pushed keys via
# the Vault screen, same as any other user.
BOT_MODE=paper
BYBIT_TESTNET=true

# Operator-side legacy keys ONLY for PAPER/SHADOW operator-tenant
# smoke tests. Leave blank if not needed; they are ignored in LIVE mode.
BYBIT_READ_API_KEY=
BYBIT_READ_API_SECRET=
BYBIT_TRADE_API_KEY=
BYBIT_TRADE_API_SECRET=

# ─── Order execution polling (defaults are fine for production) ─────
ORDER_STATUS_TIMEOUT_SECONDS=30
ORDER_STATUS_POLL_INTERVAL_SECONDS=1.5

# ─── Telegram (operator notifications, optional) ────────────────────
TELEGRAM_VERIFY_ON_START=false

# ─── Kill switch path (for the sidecar's legacy-mode fallback only;
# multi-tenant mode uses per-tenant kill switches under tenant dirs) ─
KILL_SWITCH_FILE=/var/lib/aribot/.aribot/kill_switch.flag
