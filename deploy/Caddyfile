# =====================================================================
# Aribot production reverse proxy
#
# Three site blocks:
#
#   {$SITE_ADDRESS}   -> 127.0.0.1:8787  (the FastAPI sidecar)
#   aribot.app        -> 127.0.0.1:3000  (the Next.js web frontend)
#   www.aribot.app    -> 301 redirect to https://aribot.app
#
# {$SITE_ADDRESS} + {$EMAIL} come from /etc/default/caddy. The web
# blocks are hardcoded to aribot.app because there's no reason to
# parameterize the canonical product domain.
#
# After editing /etc/default/caddy:  systemctl reload caddy
#
# Caddy auto-fetches and renews Let's Encrypt certificates. When the DNS
# A record is set with Cloudflare proxy OFF (grey cloud), the HTTP-01
# challenge succeeds. Once the cert is issued you can flip Cloudflare
# proxy to ON (orange cloud); the cert renews via the cached account
# key without needing to grey-cloud again.
# =====================================================================

{
    email {$EMAIL}

    # NOTE: The `trusted_proxies cloudflare` directive (which auto-loads
    # Cloudflare's edge IPs) requires the third-party module
    # `caddy-cloudflare-ip` and a custom Caddy build via xcaddy. The
    # apt-installed Caddy package does NOT include it, so the directive
    # is disabled here. Consequence: X-Forwarded-For shows Cloudflare's
    # edge IP, not the real client. Acceptable for the initial deploy;
    # build a custom Caddy with xcaddy when client-IP-aware rate limiting
    # or per-IP abuse tracking becomes important.
    #
    # servers {
    #     trusted_proxies cloudflare
    # }
}

{$SITE_ADDRESS} {
    encode gzip zstd

    header {
        # 1y HSTS with preload — only enable if you're confident every
        # subdomain will have HTTPS. Drop `preload` and `includeSubDomains`
        # if you operate any HTTP-only subdomain.
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "no-referrer"
        Permissions-Policy        "geolocation=(), microphone=(), camera=()"
        # Don't advertise Caddy version.
        -Server
    }

    # Reverse-proxy everything to the loopback-bound sidecar. The sidecar
    # itself terminates no TLS (--no-tls in the systemd unit) — Caddy is
    # the only public-facing TLS endpoint.
    reverse_proxy 127.0.0.1:8787 {
        header_up Host              {host}
        header_up X-Real-IP         {remote_host}
        header_up X-Forwarded-Proto {scheme}

        # Crypto trading bots hold WebSocket-style long-lived state but
        # the sidecar's /status, /positions etc. are short request/response.
        # Generous timeouts let a stuck bot reconciliation respond before
        # the proxy gives up.
        transport http {
            read_timeout  120s
            write_timeout 120s
            dial_timeout    5s
        }
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size      50mb
            roll_keep      7
            roll_keep_for  720h
        }
        format json
        # Drop healthz noise from access logs. Comment out if you want it.
        level INFO
    }
}

# ---------------------------------------------------------------------
# Web frontend (Next.js standalone server on 127.0.0.1:3000)
# ---------------------------------------------------------------------
aribot.app {
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Permissions-Policy        "geolocation=(), microphone=(), camera=()"
        -Server
    }

    reverse_proxy 127.0.0.1:3000 {
        header_up Host              {host}
        header_up X-Real-IP         {remote_host}
        header_up X-Forwarded-Proto {scheme}

        # Next.js Server Actions can do longer-running work (the vault
        # push action does PBKDF2 derivation + libsodium + a backend
        # round-trip). 30s is a safe ceiling.
        transport http {
            read_timeout  30s
            write_timeout 30s
            dial_timeout   5s
        }
    }

    log {
        output file /var/log/caddy/aribot-app.access.log {
            roll_size      50mb
            roll_keep      7
            roll_keep_for  720h
        }
        format json
        level INFO
    }
}

# Redirect www -> apex so the canonical URL is unambiguous.
www.aribot.app {
    redir https://aribot.app{uri} permanent
}
