# =====================================================================
# Aribot web env template.
#
# Copy to /etc/aribot/web.env on the server, fill in real values, then
# `chmod 640 /etc/aribot/web.env && chown root:aribot ...`. Never commit
# a filled-in copy of this file.
#
# These are NEXT_PUBLIC_* vars: they are bundled into the BROWSER bundle
# at `next build` time. The anon key is designed for client-side use
# (RLS protects data); the service_role key MUST NOT go here.
# =====================================================================

# Supabase project that mints user JWTs. MUST match SUPABASE_URL in
# /etc/aribot/aribot.env so the sidecar accepts the same JWTs the web
# app generates.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase anon key — public-by-design, browser-exposed. Get from
# Supabase Dashboard -> Project Settings -> API -> "anon public" key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Backend sidecar URL. Loopback works because both services run on the
# same Hetzner box, but going through the public hostname keeps TLS
# pinning + auth headers identical to what a remote client would send.
# Server Actions are the only consumers; the browser never hits this
# directly.
NEXT_PUBLIC_ARIBOT_API_URL=https://api.aribot.app
