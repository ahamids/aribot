# Bot runtime mode:
# - paper: no Bybit credentials required; skips authenticated startup reconciliation
# - shadow: requires validated Bybit keypairs (via .env or iOS vault); runs
#   authenticated startup checks and reconciliation
# - live: REQUIRES iOS-pushed credentials via the sidecar. The bot refuses
#   to start in LIVE mode without keys pushed through the iOS app. The
#   BYBIT_* env vars below are ignored entirely in LIVE.
BOT_MODE=paper

# Use Bybit testnet endpoints when true. Switch to false for mainnet promotion.
BYBIT_TESTNET=true

# Safety file path. If this file exists, startup aborts and runtime should halt.
KILL_SWITCH_FILE=kill_switch.flag

# Bybit read-only API keypair.
# DEPRECATED for LIVE mode — push via the iOS Vault screen instead. Still
# honored in PAPER (optional) and SHADOW (required) modes for backwards
# compatibility with local-dev workflows. Will be removed in a future release.
BYBIT_READ_API_KEY=replace_with_readonly_key
BYBIT_READ_API_SECRET=replace_with_readonly_secret

# Bybit trade-only API keypair (same DEPRECATED notice as above).
BYBIT_TRADE_API_KEY=replace_with_trade_key
BYBIT_TRADE_API_SECRET=replace_with_trade_secret

# Startup Telegram verification toggle. In live mode, verification failures block startup.
TELEGRAM_VERIFY_ON_START=true

# Order terminal-state polling controls used by order_executor.py.
ORDER_STATUS_TIMEOUT_SECONDS=30
ORDER_STATUS_POLL_INTERVAL_SECONDS=1.5

# ─── status_server.py / iOS app integration ────────────────────────────────
#
# Bearer token for the iOS app to call /status, /positions, /start, etc.
# Required by the sidecar (without it, all protected endpoints 503).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ARIBOT_API_TOKEN=

# Optional separate token for the /credentials* endpoints. If unset, the
# sidecar falls back to ARIBOT_API_TOKEN. Setting a dedicated value means a
# leaked control token cannot push or wipe Bybit credentials.
ARIBOT_API_TOKEN_VAULT=
