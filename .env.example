# Bot runtime mode:
# - paper: no Bybit credentials required; skips authenticated startup reconciliation
# - shadow: requires validated Bybit keypairs; runs authenticated startup checks and reconciliation
# - live: same startup requirements as shadow; reserved for real-money promotion path
BOT_MODE=paper

# Use Bybit testnet endpoints when true. Switch to false for mainnet promotion.
BYBIT_TESTNET=true

# Safety file path. If this file exists, startup aborts and runtime should halt.
KILL_SWITCH_FILE=kill_switch.flag

# Bybit read-only API keypair (required for shadow/live startup checks and reconciliation)
BYBIT_READ_API_KEY=replace_with_readonly_key
BYBIT_READ_API_SECRET=replace_with_readonly_secret

# Bybit trade-only API keypair (required for shadow/live permission validation; withdraw must be disabled)
BYBIT_TRADE_API_KEY=replace_with_trade_key
BYBIT_TRADE_API_SECRET=replace_with_trade_secret

# Startup Telegram verification toggle. In live mode, verification failures block startup.
TELEGRAM_VERIFY_ON_START=true

# Order terminal-state polling controls used by order_executor.py.
ORDER_STATUS_TIMEOUT_SECONDS=30
ORDER_STATUS_POLL_INTERVAL_SECONDS=1.5
